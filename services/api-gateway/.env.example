SERVER_PORT=8080

# Downstream service URIs (routing targets)
AUTH_SERVICE_URI=http://localhost:8081
APPLICATION_SERVICE_URI=http://localhost:8082
PORTAL_SERVICE_URI=http://localhost:8083

# Shared HS256 secret (>= 32 bytes) — must match auth-service / downstream services
JWT_SECRET=change-me-in-prod-this-must-be-at-least-32-bytes-long

# Redis backs the distributed rate limiter
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Rate limiting — requests per minute per user (per-second replenish is derived from this)
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Allowed browser origin (Vite dev server). chrome-extension:// origins are matched by pattern.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# --- TLS termination (production only; DISABLED for local dev) ---
# In production, TLS terminates at the gateway. Provide the keystore via env and
# enable the server.ssl.* block in application.yml.
# TLS_KEYSTORE_PATH=/etc/tls/gateway.p12
# TLS_KEYSTORE_PASSWORD=changeit
